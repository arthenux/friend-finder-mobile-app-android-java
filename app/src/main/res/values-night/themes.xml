<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.FriendFinderMobileApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/text_primary</item>
        <item name="colorOnPrimaryContainer">@color/text_inverse</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOutline">@color/outline</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialCardViewStyle">@style/Widget.FriendFinder.Card</item>
        <item name="materialButtonStyle">@style/Widget.FriendFinder.Button</item>
        <item name="textInputStyle">@style/Widget.FriendFinder.TextInputLayout</item>
        <item name="editTextStyle">@style/Widget.FriendFinder.TextInputEditText</item>
    </style>
</resources>
